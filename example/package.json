{
  "name": "enterprise-starter",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vike dev",
    "build": "vike build",
    "preview": "vike build && vike preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx database/sqlite/run-migrations.ts",
    "db:seed": "tsx database/sqlite/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/tanstack-react-query": "^11.0.0",
    "@vikejs/fastify": "^0.2.4",
    "ag-grid-community": "^33.0.0",
    "ag-grid-react": "^33.0.0",
    "better-sqlite3": "^12.6.0",
    "dotenv": "^17.0.0",
    "fastify": "^5.8.5",
    "fastify-raw-body": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vike": "^0.4.253",
    "vike-react": "^0.6.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "vitest": "^3.2.0"
  }
}
